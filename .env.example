APP_NAME="Screenplay Readers Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://portal.screenplayreaders.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=screenplayreaders_portal
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=mailersend
MAIL_FROM_ADDRESS="portal@screenplayreaders.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILERSEND_API_KEY=
MAILERSEND_ASSIGNMENT_TEMPLATE_ID=neqvygm95xdl0p7w
MAILERSEND_INVOICE_TEMPLATE_ID=vywj2lpzxepg7oqz

# Google Drive API (configured via GoogleDriveService)
# GOOGLE_APPLICATION_CREDENTIALS = absolute path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_SCRIPTS_FOLDER_ID=
GOOGLE_DRIVE_COVERAGE_FOLDER_ID=
GOOGLE_DRIVE_INVOICE_FOLDER_ID=1tuXzuzdhp96qD3xWlLb-XIa31nkZK5G-

# Incoming assignment webhook — shared secret sent as Bearer token from WordPress
PORTAL_WEBHOOK_SECRET=

# DigitalOcean Spaces (S3-compatible object storage for finalized files)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com

VITE_APP_NAME="${APP_NAME}"
